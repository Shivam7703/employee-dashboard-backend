{
  "name": "backend",
  "version": "1.0.0",
  "description": "Employee Management System Backend with MongoDB Atlas",
  "main": "server.js",
   "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node src/seeds/adminSeeder.js",
    "seed:dev": "nodemon src/seeds/adminSeeder.js",
    "dev:seed": "npm run seed && npm run dev",
    "reset": "node src/seeds/resetDatabase.js",
    "reset:seed": "npm run reset && npm run seed"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.5.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "socket.io": "^4.7.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express-validator": "^7.0.1",
    "node-cron": "^3.0.3",
    "pdfkit": "^0.14.0",
    "multer": "^1.4.5-lts.1",
    "express-rate-limit": "^6.10.0",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "compression": "^1.7.4",
    "nodemailer": "^6.9.5",
    "aws-sdk": "^2.1473.0",
    "redis": "^4.6.7",
    "joi": "^17.10.1",
    "multer-s3": "^3.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}